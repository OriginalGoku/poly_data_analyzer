{
  "name": "band_drop_recovery_sweep",
  "description": "Per-band drop-recovery base rate sweep: % drop from tipoff favorite price -> recovery to tipoff price. NBA-only universe; PnL/fees columns are discarded by the page-side aggregator.",
  "universe_filter": {
    "name": "first_k_above",
    "params": {
      "k": 1,
      "min_price": 0.50,
      "exclude_inferred_price_quality": false
    }
  },
  "side_target": "favorite",
  "trigger": {
    "name": "pct_drop_window",
    "params": {
      "anchor": "tipoff",
      "drop_pct": {"sweep": [10, 20, 30, 40, 50, 60, 70, 80, 90, 95]},
      "window_seconds_after_tipoff": null
    }
  },
  "exit": {
    "name": "reversion_to_open",
    "params": {}
  },
  "lock": {
    "mode": "sequential",
    "max_entries": 1,
    "cool_down_seconds": 0,
    "allow_re_arm_after_stop_loss": false
  },
  "fee_model": "taker"
}
